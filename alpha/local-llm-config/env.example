# Copy to .env and edit to override the defaults baked into docker-compose.yml.
# The stack runs fine without a .env — these values just mirror the compose defaults.

# ---- Ollama tuning (see README.md "VRAM tips" for the reasoning) ----

# Default context window for all models, in tokens. 32k is a good balance on 32GB VRAM;
# the KV cache grows with this, so don't crank it to 256k unless you mean it.
OLLAMA_CONTEXT_LENGTH=32768

# Flash attention. Required for KV-cache quantization below, and saves VRAM on its own. 1=on.
OLLAMA_FLASH_ATTENTION=1

# Quantize the KV cache to shrink context memory: f16 | q8_0 | q4_0.
# q8_0 roughly halves KV-cache VRAM with negligible quality loss. Requires flash attention.
OLLAMA_KV_CACHE_TYPE=q8_0

# How long a model stays resident in VRAM after its last request.
# -1 = keep forever, 0 = unload immediately, or a duration like 30m.
OLLAMA_KEEP_ALIVE=30m

# How many models may be resident at once. Bump to 2 to keep e.g. a chat model and a
# coding model both hot (uses more VRAM; fine for two sub-30B MoE models on a 5090).
OLLAMA_MAX_LOADED_MODELS=1

# ---- Open WebUI ----
# true  = login screen; the FIRST account you create becomes admin.
# false = no auth at all. Only use false if the box is trusted and local-only.
WEBUI_AUTH=true
